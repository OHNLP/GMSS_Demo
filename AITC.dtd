<!ENTITY name "AIDE4HF_schema_1_0">

<!-- version 1.2
     HF drug-class elements (ACEi, ARB, ARNI, betaBlockers, Diuretics,
     Ivabradine, MRA, SGLT, Vasodilator) now carry full prescription
     attributes from MedXN output.  The generic <Medication> element is
     retained as a fallback for drugs that cannot be mapped to an HF class.
     HFSymptoms retains context attributes only (no prescription detail).
-->

<!-- ================================================================
     SHARED ATTRIBUTE SET — context (all elements)
     certainty  : assertion status from MedTagger / default confirmed
     status     : present (current encounter) | history (past)
     experiencer: patient | other (family member etc.)
     exclusion  : flag annotation for exclusion from analysis
     comment    : sentence context or adjudication note
     ================================================================ -->

<!-- ================================================================
     SHARED ATTRIBUTE SET — prescription detail (HF drug class elements)
     Populated from MedXN pipe-delimited output columns:
       rxnorm_cui        col [2]  RxNorm concept ID of the surface form
       dose              col [3]  e.g. "40 mg"
       strength          col [4]  e.g. "12.5 MG" (when present)
       form              col [5]  e.g. "pill", "tablet"
       route             col [6]  e.g. "p.o.", "IV"
       frequency         col [7]  e.g. "daily", "twice daily | as needed"
       duration          col [8]  e.g. "5 days"
       normalized_name   col [9]  RxNorm normalized drug+strength string
       rxnorm_cui_normalized col [10] RxNorm CUI of the normalized form
     ================================================================ -->

<!ELEMENT ACEi ( #PCDATA ) >
<!ATTLIST ACEi spans              CDATA #REQUIRED >
<!ATTLIST ACEi text               CDATA #REQUIRED >
<!ATTLIST ACEi id                 CDATA #REQUIRED >
<!ATTLIST ACEi rxnorm_cui         CDATA #IMPLIED >
<!ATTLIST ACEi dose               CDATA #IMPLIED >
<!ATTLIST ACEi strength           CDATA #IMPLIED >
<!ATTLIST ACEi form               CDATA #IMPLIED >
<!ATTLIST ACEi route              CDATA #IMPLIED >
<!ATTLIST ACEi frequency          CDATA #IMPLIED >
<!ATTLIST ACEi duration           CDATA #IMPLIED >
<!ATTLIST ACEi normalized_name    CDATA #IMPLIED >
<!ATTLIST ACEi rxnorm_cui_normalized CDATA #IMPLIED >
<!ATTLIST ACEi certainty    ( confirmed | hypothetical | possible | negated ) #IMPLIED >
<!ATTLIST ACEi status       ( history | present ) #IMPLIED >
<!ATTLIST ACEi experiencer  ( patient | other )  #IMPLIED >
<!ATTLIST ACEi exclusion    ( yes | no )         #IMPLIED >
<!ATTLIST ACEi comment      CDATA #IMPLIED >

